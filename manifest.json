{
  "manifest_version": 3,
  "name": "Cookies Blocker",
  "version": "1.0.0",
  "description": "Automatically rejects cookie consent banners and optionally clears cookies on domain exit.",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "cmp/onetrust.js",
        "cmp/cookiebot.js",
        "cmp/didomi.js",
        "cmp/usercentrics.js",
        "cmp/fastcmp.js",
        "content-script.js"
      ]
    }
  ],
  "action": {
    "default_title": "Cookies Blocker",
    "default_popup": "popup.html"
  }
}
