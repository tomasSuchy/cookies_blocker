{
  "manifest_version": 3,
  "name": "Cookies Blocker",
  "version": "1.0.0",
  "description": "Automatically rejects cookie consent banners and optionally clears cookies on domain exit.",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Cookies Blocker",
    "default_popup": "popup.html"
  }
}
